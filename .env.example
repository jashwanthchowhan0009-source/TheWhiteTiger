# ===== Jarvis configuration =====
# Copy this file to `.env` and fill in your keys.

# --- LLM backend ---
# Which provider runs the brain. Options: claude (default), ollama, openai, gemini
JARVIS_PROVIDER=claude

# Anthropic (Claude) — the fully-featured backend (tools, memory, thinking).
# Get a key at https://console.anthropic.com/
ANTHROPIC_API_KEY=

# Model id. Default is the latest, most capable Claude.
# Options: claude-opus-4-8, claude-sonnet-4-6, claude-haiku-4-5
JARVIS_MODEL=claude-opus-4-8

# Reasoning effort: low | medium | high | max
JARVIS_EFFORT=high

# --- Ollama (local, free, no key) ---
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=llama3.1

# --- Google Gemini (FREE tier — get a key at https://aistudio.google.com) ---
# Set JARVIS_PROVIDER=gemini to use it. Supports tools (files/shell/memory).
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash

# --- OpenAI (optional, pluggable) ---
OPENAI_API_KEY=

# --- Behaviour ---
# Allow Jarvis to run shell commands via its tool (true/false).
JARVIS_ALLOW_SHELL=true
# Ask before every shell command runs (true/false).
JARVIS_CONFIRM_SHELL=true
